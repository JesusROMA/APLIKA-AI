# ============================================================================
# Aplika.ai — Variables de entorno (EJEMPLO)
# Regla #0: TODO es nuevo y exclusivo de Aplika. No reutilizar credenciales de
# ningún otro proyecto. Copia este archivo a `.env.local` (dev) o `.env` (Docker)
# y rellena con TUS valores nuevos. Nunca versiones el archivo real.
# ============================================================================

# ---------------------------------------------------------------------------
# Supabase (proyecto NUEVO de Aplika)
# ---------------------------------------------------------------------------
# URL pública del proyecto Supabase de Aplika (https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key (segura para el navegador; RLS la protege)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SOLO servidor. Bypassea RLS. Jamás exponer al cliente.
APLIKA_SUPABASE_SERVICE_ROLE_KEY=
# Connection string directa (migraciones / supabase CLI)
APLIKA_SUPABASE_DB_URL=

# ---------------------------------------------------------------------------
# Stripe (cuenta NUEVA de Aplika) — modelo estándar (single account)
# ---------------------------------------------------------------------------
# Clave secreta — SOLO servidor. El frontend solo muestra "sk_live_••••".
APLIKA_STRIPE_SECRET_KEY=
# Publishable key (frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secreto de verificación de firma del webhook (whsec_...)
APLIKA_STRIPE_WEBHOOK_SECRET=
# Preparado para Connect (parametrizable por tenant). Vacío = modo estándar.
APLIKA_STRIPE_CONNECT_ENABLED=false

# ---------------------------------------------------------------------------
# Facturación CFDI 4.0 — adaptador PacProvider
# ---------------------------------------------------------------------------
# Proveedor activo: stub | facturama | finkok | sw
APLIKA_PAC_PROVIDER=stub
# Credenciales del PAC real (se usan cuando PROVIDER != stub)
APLIKA_PAC_API_URL=
APLIKA_PAC_USERNAME=
APLIKA_PAC_PASSWORD=
APLIKA_PAC_API_KEY=

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Dominio raíz para resolución multi-tenant por subdominio
# (ej. refanorte.aplika.shop -> tenant "refanorte")
APLIKA_ROOT_DOMAIN=aplika.shop
# URL pública base de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secreto para firmar acciones internas (impersonación, etc.)
APLIKA_INTERNAL_SECRET=

# ---------------------------------------------------------------------------
# Notificaciones de leads (landing) — opcional
# ---------------------------------------------------------------------------
APLIKA_LEADS_NOTIFY_EMAIL=hola@aplika.ai
APLIKA_SMTP_URL=
