{
  "name": "aplika-erp",
  "version": "0.1.0",
  "private": true,
  "description": "Aplika.ai — ERP ligero multi-tenant para venta al mayoreo (Next.js + Supabase + Stripe + CFDI 4.0)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "powershell -ExecutionPolicy Bypass -File scripts/auto-sync.ps1",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:seed": "supabase db reset --linked=false"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^16.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
